# CodePilot AI Workspace - Environment Variables
# Copy this file to .env and fill in your values

# ============================================
# APPLICATION
# ============================================
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# ============================================
# DATABASE
# ============================================
# Local PostgreSQL (Development)
# DATABASE_URL="postgresql://postgres:password@localhost:5432/codepilot_ai?schema=public"

# Cloud PostgreSQL with Connection Pooling (Recommended for Production)
#
# Neon (Serverless PostgreSQL with built-in pooling)
# Use the pooled connection URL (ends with -pooler.neon.tech)
DATABASE_URL="postgresql://username:password@host-pooler.region.aws.neon.tech/database?sslmode=require"
# Optional: Direct connection URL for migrations (non-pooled)
DIRECT_DATABASE_URL="postgresql://username:password@host.region.aws.neon.tech/database?sslmode=require"

# Supabase (with connection pooling via Supavisor)
# DATABASE_URL="postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_DATABASE_URL="postgresql://postgres.project-ref:password@aws-0-region.pooler.supabase.com:5432/postgres"

# Railway (with connection pooling)
# DATABASE_URL="postgresql://postgres:password@containers-us-west-region.railway.app:port/railway?sslmode=require"

# Connection Pool Settings (Optional - Prisma defaults are usually sufficient)
# DATABASE_CONNECTION_LIMIT=10
# DATABASE_POOL_TIMEOUT=10

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRES_IN=30d

# ============================================
# CORS
# ============================================
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ============================================
# GITHUB API (Optional)
# ============================================
GITHUB_TOKEN=your-github-personal-access-token
GITHUB_API_URL=https://api.github.com

# ============================================
# IBM BOB AI (Integration Ready)
# ============================================
IBM_BOB_API_KEY=your-ibm-bob-api-key
IBM_BOB_API_URL=https://api.ibm.com/bob/v1
IBM_BOB_MODEL=bob-v1

# ============================================
# FILE UPLOADS
# ============================================
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# ============================================
# REDIS (For Queue System)
# ============================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ============================================
# RATE LIMITING
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ============================================
# EMAIL (Optional - for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@codepilot.ai